# HackerRank Orchestrate — .gitignore

# ── SECRETS — Never commit ──────────────────────────────────────────────────
.env
*.env
.env.local        # .env.local is the template (no real key), safe to commit

# ── Python artefacts ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Runtime outputs (generated, do not commit raw run data) ─────────────────
code/.cache/
code/telemetry.jsonl

# ── Submission artefacts (commit these deliberately before submitting) ───────
# output.csv — generated by main.py — commit only the final version
# code.zip   — generated by scripts/package.py

# ── OS / editor junk ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Node (not used but safe) ─────────────────────────────────────────────────
node_modules/
